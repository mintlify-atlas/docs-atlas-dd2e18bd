  "keyFeatures": [
    "Chrome session-based sync — no API key required (macOS)",
    "OAuth v2 API sync for cross-platform use",
    "SQLite FTS5 full-text search with BM25 ranking",
    "LLM-powered bookmark classification by category and subject domain",
    "Regex-based fast classification (no LLM cost)",
    "ANSI terminal dashboard with sparklines and category breakdowns",
    "AI agent integration — works with Claude Code, Codex, and any shell-capable agent",
    "Local-first: all data stored in ~/.ft-bookmarks/, no telemetry",
    "Cron-friendly for automated daily syncing",
    "Media asset download support"
  ],
  "publicApiSurface": [
    "ft sync",
